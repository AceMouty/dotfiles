# Reload config
super + Escape
  pkill -USR1 -x sxhkd

# Basic programs {{

super + l
  betterlockscreen -l

mod1 + shift + Print
  maim -s | tee Pictures/ScreenShots/$(date +%b%d::%H%M%S).png | xclip -selection clipboard -t image/png

mod1 + Print
 maim -s | xclip -selection clipboard -t image/png

mod1 + Return
  alacritty

mod1 + d
 dmenu_run -fn "Operator Mono Nerd Font-16" 

mod1 + r
  alacritty -e ranger

mod1 + p
  spacefm

super + p
  pavucontrol

# }}


# Screen Brightness
XF86MonBrightnessUp
  xbacklight -inc 10

XF86MonBrightnessDown
  xbacklight -dec 10

# Volume Keys
super + {Up,Down}
  pamixer {-i,-d} 10

super + m
  pamixer -t
